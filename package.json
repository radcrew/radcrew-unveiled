{
  "name": "radcrew-unveiled",
  "private": true,
  "type": "module",
  "workspaces": ["frontend"],
  "scripts": {
    "dev": "concurrently -n frontend,api -c cyan,magenta \"npm run dev -w frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "build:frontend": "npm run build -w frontend",
    "build:dev": "npm run build:dev -w frontend",
    "lint": "eslint frontend/src",
    "preview": "npm run preview -w frontend",
    "test": "npm run test -w frontend",
    "test:watch": "npm run test:watch -w frontend",
    "dev:backend": "cd backend_py && python -m uvicorn app.main:app --host 0.0.0.0 --reload --reload-dir app",
    "test:backend": "cd backend_py && python -m pytest",
    "build:backend": "cd backend_py && python -m compileall -q app"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@eslint/js": "^9.32.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "typescript-eslint": "^8.38.0"
  }
}
