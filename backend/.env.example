PORT=8787
# Per-client API request budget (slowapi limit string).
RATE_LIMIT=25/minute
FRONTEND_ORIGIN=http://localhost:8080
# Optional: comma-separated origins (if set, used for CORS instead of FRONTEND_ORIGIN only).
# Production example: FRONTEND_ORIGINS=https://radcrew.org,https://www.radcrew.org
FRONTEND_ORIGINS=

HF_TOKEN=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGINGFACE_PROVIDER=auto
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_EMBEDDING_PROVIDER=hf-inference

GITHUB_REPO_URL=
GITHUB_TOKEN=
GITHUB_BRANCH=
GITHUB_PATH=
GITHUB_PRIVATE_REPO=false

COMPANY_FEEDBACK_EMAIL=code@radcrew.org
WEB3FORMS_ACCESS_KEY=

# Deep search: web-search fallback used only when the knowledge base can't
# confidently answer. Inert unless WEB_SEARCH_API_KEY is set.
DEEP_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
# Retrieval similarity thresholds (0.0–1.0): below the first, retrieval falls
# back to lexical keyword matching; below the second, the web search runs.
RETRIEVAL_FALLBACK_SIMILARITY_THRESHOLD=0.25
DEEP_SEARCH_SIMILARITY_THRESHOLD=0.30