PORT=8787
FRONTEND_ORIGIN=http://localhost:8080
HUGGINGFACE_API_KEY=
# If HUGGINGFACE_API_KEY is unset or empty, HF_TOKEN is used.
HF_TOKEN=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# Inference provider: hf-inference | auto | together | groq | … (see HF Inference Providers docs)
HUGGINGFACE_PROVIDER=hf-inference
# Embedding model/provider used by hybrid semantic retrieval.
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_EMBEDDING_PROVIDER=hf-inference

# Optional GitHub Markdown knowledge source for RAG ingestion at startup.
GITHUB_KB_REPO_URL=
# Personal access token with repo read access; required if GITHUB_KB_PRIVATE_REPO=true.
GITHUB_KB_TOKEN=
# Branch or ref for the Git tree (required when GITHUB_KB_REPO_URL is set).
GITHUB_KB_BRANCH=
# Optional directory path within the repo (e.g. docs/knowledge).
GITHUB_KB_PATH=
# Set true for private repositories to enforce token usage.
GITHUB_KB_PRIVATE_REPO=false

# Contentful — Content Delivery API (same values as frontend VITE_CONTENTFUL_*; used at API startup for RAG).
CONTENTFUL_SPACE_ID=
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_ENVIRONMENT=master
# Comma-separated Contentful content type ids to ingest (default: engineers team profiles).
CONTENTFUL_RAG_CONTENT_TYPES=engineers

# Company feedback via Web3Forms (https://web3forms.com). Create an access key in their dashboard; recipient inbox is set there.
# Leave empty to disable sending. COMPANY_FEEDBACK_EMAIL is optional copy for user-facing messages (align with your Web3Forms inbox).
COMPANY_FEEDBACK_EMAIL=code@radcrew.org
WEB3FORMS_ACCESS_KEY=
