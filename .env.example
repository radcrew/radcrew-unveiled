# Contentful — Content Delivery API (read-only, safe for public sites; still exposed in browser bundle)
# Create: Contentful app → Space → Settings → API keys → Content delivery / preview tokens
VITE_CONTENTFUL_SPACE_ID=
VITE_CONTENTFUL_DELIVERY_TOKEN=
# Optional; default in SDK is often "master"
VITE_CONTENTFUL_ENVIRONMENT=master
